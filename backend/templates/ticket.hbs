<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { margin: 0; padding: 0; background: #f4f1ea; color: #1f2933; font-family: Arial, sans-serif; line-height: 1.6; }
    .container { max-width: 680px; margin: 0 auto; padding: 32px 18px; }
    .card { background: #ffffff; border: 1px solid #e4dccd; border-radius: 18px; overflow: hidden; }
    .header { background: #111827; color: #fbbf24; padding: 28px; text-align: center; }
    .content { padding: 28px; }
    .summary { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 14px; padding: 16px; margin: 20px 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 12px; }
    th, td { padding: 10px 6px; border-bottom: 1px solid #e5e7eb; text-align: left; vertical-align: top; }
    th { color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }
    .total { text-align: right; font-size: 20px; font-weight: 700; margin-top: 18px; }
    .note { background: #ecfdf5; border-left: 4px solid #10b981; padding: 12px 14px; border-radius: 10px; }
    .footer { padding: 18px 28px 28px; color: #6b7280; font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <h1>Your booking is confirmed</h1>
        <p>Booking number: <strong>{{bookingNumber}}</strong></p>
      </div>
      <div class="content">
        <p>Hi <strong>{{userName}}</strong>,</p>
        <p>Your payment was successful. Your tickets and admission passes are now ready in your TicketStage account.</p>

        <div class="summary">
          <table>
            <thead>
              <tr>
                <th>Event</th>
                <th>Ticket</th>
                <th>Qty</th>
                <th>Subtotal</th>
              </tr>
            </thead>
            <tbody>
              {{#each tickets}}
              <tr>
                <td>
                  <strong>{{this.eventName}}</strong><br>
                  <span>{{this.date}}</span><br>
                  <span>{{this.venue}}</span>
                </td>
                <td>{{this.ticketName}}</td>
                <td>x{{this.quantity}}</td>
                <td>{{this.subtotal}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <div class="total">Total paid: {{totalAmount}}</div>
        </div>

        <div class="note">
          Please bring your QR/barcode pass and a valid ID when checking in at the venue.
        </div>
      </div>
      <div class="footer">
        <p>TicketStage - thank you for your purchase.</p>
      </div>
    </div>
  </div>
</body>
</html>
