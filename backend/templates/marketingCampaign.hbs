<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { margin: 0; padding: 0; background: #f4f1ea; color: #1f2933; font-family: Arial, sans-serif; line-height: 1.6; }
    .container { max-width: 620px; margin: 0 auto; padding: 32px 18px; }
    .card { background: #ffffff; border: 1px solid #e4dccd; border-radius: 18px; overflow: hidden; }
    .header { background: #7c2d12; color: #ffffff; padding: 28px; text-align: center; }
    .content { padding: 28px; }
    .button { display: inline-block; padding: 12px 20px; background: #ea580c; color: #ffffff; border-radius: 999px; text-decoration: none; font-weight: 700; }
    .footer { padding: 18px 28px 28px; color: #6b7280; font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <h1>{{headline}}</h1>
      </div>
      <div class="content">
        <p>{{message}}</p>
        {{#if ctaUrl}}
        <p style="text-align: center; margin: 30px 0;">
          <a class="button" href="{{ctaUrl}}">{{ctaLabel}}</a>
        </p>
        {{/if}}
        <p>{{footerMessage}}</p>
      </div>
      <div class="footer">
        <p>You are receiving this because you opted in to TicketStage marketing emails.</p>
        <p><a href="{{unsubscribeUrl}}">Manage preferences</a> | <a href="{{unsubscribeApiUrl}}">Unsubscribe instantly</a></p>
      </div>
    </div>
  </div>
</body>
</html>
