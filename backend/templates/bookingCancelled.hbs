<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { margin: 0; padding: 0; background: #f4f1ea; color: #1f2933; font-family: Arial, sans-serif; line-height: 1.6; }
    .container { max-width: 620px; margin: 0 auto; padding: 32px 18px; }
    .card { background: #ffffff; border: 1px solid #e4dccd; border-radius: 18px; overflow: hidden; }
    .header { background: #374151; color: #ffffff; padding: 28px; text-align: center; }
    .content { padding: 28px; }
    .reason { background: #fef2f2; border-left: 4px solid #ef4444; padding: 12px 14px; border-radius: 10px; }
    .footer { padding: 18px 28px 28px; color: #6b7280; font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <h1>Booking cancelled</h1>
        <p>Booking number: <strong>{{bookingNumber}}</strong></p>
      </div>
      <div class="content">
        <p>Hi <strong>{{userName}}</strong>,</p>
        <p>Your TicketStage booking has been cancelled.</p>
        <div class="reason">
          <strong>Reason:</strong> {{reason}}
        </div>
        <p>If this was unexpected, please contact support with your booking number.</p>
      </div>
      <div class="footer">
        <p>TicketStage booking notification.</p>
      </div>
    </div>
  </div>
</body>
</html>
