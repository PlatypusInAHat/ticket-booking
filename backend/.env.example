# Server Configuration
PORT=5000
NODE_ENV=development

# Microservices
SERVICE_MODE=microservice
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5101
CATALOG_SERVICE_PORT=5102
BOOKING_SERVICE_PORT=5103
CHECKIN_SERVICE_PORT=5104

AUTH_SERVICE_URL=http://localhost:5101
CATALOG_SERVICE_URL=http://localhost:5102
BOOKING_SERVICE_URL=http://localhost:5103
CHECKIN_SERVICE_URL=http://localhost:5104

AUTH_MONGODB_URI=mongodb://localhost:27017/ticket-auth
CATALOG_MONGODB_URI=mongodb://localhost:27017/ticket-catalog
BOOKING_MONGODB_URI=mongodb://localhost:27017/ticket-booking
CHECKIN_MONGODB_URI=mongodb://localhost:27017/ticket-checkin
MONGODB_CONNECT_RETRIES=10
MONGODB_CONNECT_RETRY_DELAY_MS=2000

EVENT_BROKER_URL=amqp://localhost:5672
EVENT_EXCHANGE=ticket-booking.events
EVENT_BROKER_RETRIES=10
EVENT_BROKER_RETRY_DELAY_MS=2000
OUTBOX_ENABLED=true
OUTBOX_PUBLISH_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=20
OUTBOX_LOCK_TIMEOUT_MS=60000

INTERNAL_API_KEY=change_this_internal_key
SECRET_HASH_KEY=change_this_secret_hash_key

# Database
MONGODB_URI=mongodb://localhost:27017/ticket-booking
# or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ticket-booking

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Password hashing
PASSWORD_HASH_ROUNDS=12
PASSWORD_PEPPER=change_this_password_pepper
MIN_PASSWORD_LENGTH=8

# Email (optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/payment/return/vnpay
VNPAY_IPN_URL=http://localhost:5000/api/payment/webhooks/vnpay

# MoMo
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_REDIRECT_URL=http://localhost:3000/payment/result
MOMO_IPN_URL=http://localhost:5000/api/payment/webhooks/momo
MOMO_REQUEST_TYPE=captureWallet

# Public URLs used by payment gateways
PUBLIC_API_URL=http://localhost:5000

# Booking hold and high-traffic checkout
BOOKING_HOLD_MINUTES=15
BOOKING_EXPIRATION_INTERVAL_MS=30000
BOOKING_EXPIRATION_BATCH_SIZE=50
BOOKING_EXPIRATION_WORKER_ENABLED=true
BOOKING_QUEUE_ENABLED=true
BOOKING_QUEUE_CONCURRENCY=5
BOOKING_QUEUE_MAX_SIZE=500
BOOKING_QUEUE_WAIT_TIMEOUT_MS=30000
RATE_LIMIT_ENABLED=true
BOOKING_CREATE_RATE_LIMIT_WINDOW_MS=60000
BOOKING_CREATE_RATE_LIMIT_MAX=8
PAYMENT_RATE_LIMIT_WINDOW_MS=60000
PAYMENT_RATE_LIMIT_MAX=12

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Email
ADMIN_EMAIL=admin@ticketbooking.com
