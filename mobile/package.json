{
  "name": "ticket-booking-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "powershell -ExecutionPolicy Bypass -File scripts/run-android.ps1",
    "android:build": "powershell -ExecutionPolicy Bypass -File scripts/gradle.ps1 assembleDebug",
    "android:install": "powershell -ExecutionPolicy Bypass -File scripts/gradle.ps1 app:installDebug",
    "android:gradle": "powershell -ExecutionPolicy Bypass -File scripts/gradle.ps1",
    "android:expo": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "^51.0.0",
    "expo-camera": "~15.0.16",
    "expo-clipboard": "~6.0.3",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-nfc-manager": "^3.16.1",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
